<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="petcare.Controls.BottomNav"
    x:Name="ThisNav"
    HeightRequest="45">

    <Grid Padding="10"
          ColumnDefinitions="*,*,*,*">

        <!-- HOME -->
        <ImageButton Grid.Column="0"
                     Source="{Binding HomeIcon}"
                     Clicked="OnHomeClicked"
                     BackgroundColor="Transparent"
                     HeightRequest="18"
                     WidthRequest="20"
                     HorizontalOptions="Center"/>

        <!-- PETS -->
        <ImageButton Grid.Column="1"
                     Source="{Binding PetsIcon}"
                     Clicked="OnPetsClicked"
                     BackgroundColor="Transparent"
                     HeightRequest="18"
                     WidthRequest="20"
                     HorizontalOptions="Center"/>

        <!-- APPOINTMENTS -->
        <ImageButton Grid.Column="2"
                     Source="{Binding AppointmentsIcon}"
                     Clicked="OnAppointmentsClicked"
                     BackgroundColor="Transparent"
                     HeightRequest="18"
                     WidthRequest="20"
                     HorizontalOptions="Center"/>

        <!-- PROFILE -->
        <ImageButton Grid.Column="3"
                     Source="{Binding ProfileIcon}"
                     Clicked="OnProfileClicked"
                     BackgroundColor="Transparent"
                     HeightRequest="18"
                     WidthRequest="20"
                     HorizontalOptions="Center"/>

    </Grid>

</ContentView>