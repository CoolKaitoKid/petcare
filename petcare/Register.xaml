<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="petcare.Register"
             Title="Register"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#3C280D">

    <Grid>

        <Image Source="register_pet.jpg"
               Aspect="AspectFill" />

        <BoxView BackgroundColor="#99000000" />

        <ScrollView>
            <VerticalStackLayout Padding="28,45,28,25"
                                 Spacing="8">

                <Image Source="pet_logo_white.png"
                       HeightRequest="38"
                       WidthRequest="70"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />

                <Label Text="Pet care"
                       TextColor="White"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="Create an&#10;Account"
                       TextColor="White"
                       FontSize="31"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,12,0,105" />

                <Label Text="Email"
                       TextColor="White"
                       FontSize="11" />

                <Entry x:Name="TxtEmail"
                       Keyboard="Email"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       HeightRequest="30" />

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-8,0,2" />

                <Label Text="First Name"
                       TextColor="White"
                       FontSize="11" />

                <Entry x:Name="TxtFirstName"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       HeightRequest="30" />

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-8,0,2" />

                <Label Text="Last Name"
                       TextColor="White"
                       FontSize="11" />

                <Entry x:Name="TxtLastName"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       HeightRequest="30" />

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-8,0,2" />

                <Label Text="Password"
                       TextColor="White"
                       FontSize="11" />

                <Entry x:Name="TxtPassword"
                       IsPassword="True"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       HeightRequest="30" />

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-8,0,2" />

                <Label Text="Confirm Password"
                       TextColor="White"
                       FontSize="11" />

                <Entry x:Name="TxtConfirmPassword"
                       IsPassword="True"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       HeightRequest="30" />

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-8,0,18" />

                <Button Text="Register"
                        Clicked="OnRegisterClicked"
                        BackgroundColor="#9A7B4F"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="45"
                        CornerRadius="8" />

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="3"
                                       Margin="0,10,0,0">

                    <Label Text="Already have an account?"
                           TextColor="White"
                           FontSize="11" />

                    <Label Text="Login"
                           TextColor="White"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>