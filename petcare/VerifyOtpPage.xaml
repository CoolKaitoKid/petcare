<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="petcare.VerifyOtpPage"
             Title="Verify OTP"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F5F2">

    <Grid Padding="25"
          RowDefinitions="Auto,*">

        <Label Text="‹"
               FontSize="32"
               TextColor="Black">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked" />
            </Label.GestureRecognizers>
        </Label>

        <VerticalStackLayout Grid.Row="1"
                             Spacing="18"
                             VerticalOptions="Center">

            <Label Text="Enter OTP"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center" />

            <Label Text="Enter the 6-digit code sent to your email."
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <Entry x:Name="EntryOtp"
                   Placeholder="OTP Code"
                   Keyboard="Numeric"
                   MaxLength="6"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   BackgroundColor="White" />

            <Entry x:Name="EntryNewPassword"
                   Placeholder="New Password"
                   IsPassword="True"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   BackgroundColor="White" />

            <Entry x:Name="EntryConfirmPassword"
                   Placeholder="Confirm Password"
                   IsPassword="True"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   BackgroundColor="White" />

            <Button Text="Reset Password"
                    Clicked="OnResetPasswordClicked"
                    BackgroundColor="#BFA38E"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>