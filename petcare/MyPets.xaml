<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:petcare.Controls"
             x:Class="petcare.MyPets"
             Title="My Pets"
             BackgroundColor="#F8F5F2">

    <Grid RowDefinitions="*,Auto,Auto"
          Padding="20,20,20,0">

        <!-- SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="15"
                                 Padding="0,0,0,20">

                <Label Text="My Pets"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="Black" />

                <SearchBar Placeholder="Search pets..."
                           TextChanged="OnSearchChanged"
                           BackgroundColor="White" />

                <VerticalStackLayout x:Name="PetsContainer"
                                     Spacing="10" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ADD NEW PET BUTTON -->
        <Button Grid.Row="1"
                Text="+ Add New Pet"
                Clicked="OnAddPetClicked"
                BackgroundColor="#BFA38E"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="25"
                HeightRequest="50"
                Margin="0,10,0,10" />

        <!-- FIXED BOTTOM NAVIGATION BAR -->
        <controls:BottomNav Grid.Row="2"
                            CurrentPage="Pets"/>
    </Grid>
</ContentPage> 