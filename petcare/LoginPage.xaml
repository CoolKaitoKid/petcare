<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="petcare.LoginPage"
             Title="LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid>

        <Image Source="login_pet.jpg"
               Aspect="AspectFill" />

        <BoxView BackgroundColor="#1AFFFFFF" />

        <ScrollView>
            <VerticalStackLayout Padding="25,20,25,20"
                                 Spacing="0">

                <Image Source="pet_logo_black.png"
                       HeightRequest="35"
                       WidthRequest="75"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />

                <Label Text="Pet care"
                       TextColor="#333333"
                       FontSize="25"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,-4,0,18" />

                <Label Text="Welcome&#10;Back!"
                       TextColor="#2F2F2F"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,0,0,205" />

                <Label Text="Username"
                       TextColor="White"
                       FontSize="12"
                       FontAttributes="Bold" />

                <Entry x:Name="TxtEmail"
                       Keyboard="Email"
                       TextColor="White"
                       PlaceholderColor="#F8F1E8"
                       BackgroundColor="Transparent"
                       HeightRequest="32"
                       Margin="0,-8,0,0" />

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-3,0,12" />

                <Label Text="Password"
                       TextColor="White"
                       FontSize="12"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="*,35"
                      HeightRequest="32"
                      Margin="0,-8,0,0">

                    <Entry x:Name="TxtPassword"
                           Grid.Column="0"
                           IsPassword="True"
                           TextColor="White"
                           PlaceholderColor="#F8F1E8"
                           BackgroundColor="Transparent"
                           HeightRequest="32" />

                    <ImageButton x:Name="BtnTogglePassword"
                                 Grid.Column="1"
                                 Source="eye_closed.png"
                                 BackgroundColor="Transparent"
                                 Padding="8"
                                 WidthRequest="35"
                                 HeightRequest="32"
                                 Clicked="OnTogglePasswordClicked" />

                </Grid>

                <BoxView HeightRequest="1"
                         BackgroundColor="White"
                         Margin="0,-3,0,18" />

                <Button Text="Log In"
                        Clicked="OnLoginClicked"
                        BackgroundColor="White"
                        TextColor="#9A6A4A"
                        FontAttributes="Bold"
                        FontSize="13"
                        HeightRequest="45"
                        CornerRadius="22"
                        Margin="12,0,12,0" />

                <!-- CLICKABLE FORGOT PASSWORD -->
                <Label Text="Forgot Password?"
                       TextColor="White"
                       FontSize="12"
                       HorizontalOptions="Center"
                       TextDecorations="Underline"
                       Margin="0,15,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="3">

                    <Label Text="Don&apos;t have an account?"
                           TextColor="White"
                           FontSize="12" />

                    <Label Text="Register"
                           TextColor="White"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoToRegister" />
                        </Label.GestureRecognizers>
                    </Label>

                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>